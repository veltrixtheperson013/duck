DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# Hosted OpenRouter AI. Requires an OpenRouter account/API key.
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=tencent/hy3:free
OPENROUTER_SITE_URL=https://duck.local
OPENROUTER_APP_NAME=Duck Discord Bot

# How much server-wide context to send to AI planners/chat.
AI_CONTEXT_CHANNELS=all
AI_CONTEXT_MESSAGES_PER_CHANNEL=10
AI_CONTEXT_MAX_MESSAGES=500
AI_CONTEXT_MAX_CHARS=32000
AI_CONTEXT_MESSAGE_CHARS=160
AI_CONTEXT_MEMBER_LIMIT=500
AI_CONTEXT_CHANNEL_LIMIT=250
AI_CONTEXT_ROLE_LIMIT=250
AI_CONTEXT_CACHE_TTL_MS=15000
AI_CHAT_MAX_TOKENS=700
AI_CHAT_MAX_ATTEMPTS=3
AI_EXCLUDE_REASONING=true
DUCK_MESSAGE_CACHE_TTL_MS=60000
DUCK_MESSAGE_CACHE_LIMIT=150
PENDING_ACTION_TTL_MS=1800000
DUCK_QUEUE_MESSAGE=Duck is thinking...
DUCK_DEBUG=true
DUCK_DEBUG_AI_BODY=false

# Optional features ported from the older discord.py bot.
DUCK_LEGACY_PREFIXES=!,!!
DUCK_KEEP_ALIVE=false
DUCK_KEEP_ALIVE_PORT=8080
DUCK_WELCOME_CHANNEL_ID=
DUCK_LOG_CHANNEL_ID=
DUCK_CREATE_ENTRY_CHANNELS=false
DUCK_ENTRY_CATEGORY_ID=
DUCK_RULES_URL=
DUCK_ANNOUNCEMENTS_URL=
DUCK_INVITE_CLEANUP=false
DUCK_INVITE_LIFETIME_DAYS=3

# No-account local AI. Install Ollama, run `ollama pull llama3.1:8b`, then use:
# AI_PROVIDER=ollama
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# Other OpenAI-compatible AI providers.
AI_API_KEY=optional_hosted_ai_key_here
AI_BASE_URL=https://openrouter.ai/api/v1
AI_MODEL=optional_model_id_here

# Legacy Groq support. Use only if Groq login works for you.
GROQ_API_KEY=optional_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
